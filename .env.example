DATABASE_URL=postgresql+psycopg://steam:steam@localhost:5432/steamgames
SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=1440
ENVIRONMENT=development
ENABLE_VECTOR_SIMILARITY=true
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIM=384
EMBEDDING_BATCH_SIZE=64
FORCE_HTTPS=false
ALLOWED_HOSTS=localhost,127.0.0.1
TRUSTED_PROXY_CIDRS=
HSTS_MAX_AGE_SECONDS=63072000
AUTH_RATE_LIMIT_ENABLED=true
AUTH_RATE_LIMIT_WINDOW_SECONDS=900
AUTH_RATE_LIMIT_BLOCK_SECONDS=900
AUTH_RATE_LIMIT_LOGIN_EMAIL_MAX_ATTEMPTS=5
AUTH_RATE_LIMIT_LOGIN_IP_MAX_ATTEMPTS=20
AUTH_RATE_LIMIT_REGISTER_IP_MAX_ATTEMPTS=10
ENABLE_MCP_SERVER=true
MCP_MOUNT_PATH=/mcp
